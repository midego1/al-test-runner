// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Stop Watch",
			"command": "echo ${input:terminate}",
			"type": "shell",
			"problemMatcher": [],
			"presentation": {
				"echo": false,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": false,
				"close": true
			}
		},
		{
			"label": "Clean Build and Restart Watch",
			"dependsOrder": "sequence",
			"dependsOn": [
				"Stop Watch",
				"Clean Out Folder",
				"npm: watch"
			],
			"problemMatcher": []
		},
		{
			"label": "Clean Out Folder",
			"type": "shell",
			"command": "Remove-Item -Path '${workspaceFolder}/out' -Recurse -Force -ErrorAction SilentlyContinue",
			"problemMatcher": [],
			"presentation": {
				"echo": false,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": false,
				"close": true
			}
		}
	],
	"inputs": [
		{
			"id": "terminate",
			"type": "command",
			"command": "workbench.action.tasks.terminate",
			"args": "npm: watch"
		}
	]
}
